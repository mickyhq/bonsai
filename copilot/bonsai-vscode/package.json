{
  "name": "bonsai-vscode",
  "displayName": "Bonsai",
  "description": "Bonsai XML for GitHub Copilot Chat and Codex.",
  "version": "0.1.0",
  "publisher": "MickyBalladelli",
  "author": {
    "name": "Micky Balladelli"
  },
  "private": true,
  "icon": "images/bonsai.png",
  "repository": {
    "type": "git",
    "url": "file:../.."
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:bonsai.generateContext",
    "onCommand:bonsai.generateAndAsk",
    "onCommand:bonsai.copyContext",
    "onCommand:bonsai.copyProjectMap",
    "onCommand:bonsai.previewProjectMap",
    "onCommand:bonsai.openContext"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "bonsai.generateContext",
        "title": "Bonsai: Generate Context"
      },
      {
        "command": "bonsai.generateAndAsk",
        "title": "Bonsai: Generate and Ask"
      },
      {
        "command": "bonsai.copyContext",
        "title": "Bonsai: Copy Context Prompt"
      },
      {
        "command": "bonsai.copyProjectMap",
        "title": "Bonsai: Copy Project Map"
      },
      {
        "command": "bonsai.previewProjectMap",
        "title": "Bonsai: Preview Project Map"
      },
      {
        "command": "bonsai.openContext",
        "title": "Bonsai: Open Last Context"
      }
    ],
    "configuration": {
      "title": "Bonsai",
      "properties": {
        "bonsai.maxTokens": {
          "type": "number",
          "default": 12000,
          "minimum": 1000,
          "description": "Token budget for generated Copilot context."
        },
        "bonsai.level": {
          "type": "number",
          "default": 2,
          "enum": [
            1,
            2,
            3
          ],
          "description": "Compression level: 1 full-first, 2 skeleton, 3 tree map."
        },
        "bonsai.outputFile": {
          "type": "string",
          "default": "/tmp/bonsai-vscode.xml",
          "description": "File path where generated context is written."
        },
        "bonsai.outputFormat": {
          "type": "string",
          "default": "xml",
          "enum": [
            "xml",
            "json"
          ],
          "description": "Generated context format."
        },
        "bonsai.include": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Glob patterns to include, such as src/**."
        },
        "bonsai.exclude": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Glob patterns to exclude, such as **/generated/**."
        },
        "bonsai.respectGitignore": {
          "type": "boolean",
          "default": true,
          "description": "Respect .gitignore, global gitignore, and git exclude files."
        },
        "bonsai.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Optional explicit path to the bonsai binary. When empty, Bonsai checks BONSAI_BIN, PATH, then local release builds."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && node dist/bonsai.smoke.test.js",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.15.0",
    "typescript": "^5.4.5"
  }
}
